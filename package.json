{
   "name": "@adeficior/resource-merger",
   "version": "0.0.0-dev",
   "description": "Resource Merger",
   "main": "dist/index.js",
   "exports": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "bin": {
      "merge": "dist/cli/index.js"
   },
   "files": [
      "dist"
   ],
   "type": "module",
   "packageManager": "bun@1.3.14",
   "scripts": {
      "build": "tsc --project tsconfig.build.json",
      "lint": "eslint {src,test}",
      "format": "prettier --write {src,test}",
      "cli": "node dist/cli",
      "test": "bun test",
      "test:ci": "bun run lint && bun run test --coverage",
      "prepare": "husky"
   },
   "repository": {
      "type": "git",
      "url": "git+https://github.com/Adeficior/ResourceMerger.git"
   },
   "license": "ISC",
   "bugs": {
      "url": "https://github.com/PssbleTrngle/Adeficior/issues"
   },
   "homepage": "https://github.com/PssbleTrngle/Adeficior#readme",
   "devDependencies": {
      "@eslint/js": "^10.0.1",
      "@types/bun": "latest",
      "@types/command-line-usage": "^5.0.4",
      "@types/minimatch": "^3.0.5",
      "eslint": "^10.5.0",
      "husky": "^9.1.7",
      "prettier": "^3.8.4",
      "typescript": "^6.0.3",
      "typescript-eslint": "^8.61.0"
   },
   "dependencies": {
      "@adeficior/pack-resolver": "^2.0.0-rc.20",
      "arg": "^5.0.2",
      "command-line-usage": "^6.1.3",
      "minimatch": "^5.1.9",
      "node-stream-zip": "^1.15.0",
      "zip-a-folder": "^1.1.5"
   }
}